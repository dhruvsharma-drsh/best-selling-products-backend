# Use your Supabase Postgres connection string here instead of Neon.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
REDIS_URL=redis://HOST:6379
CORS_ORIGIN=https://your-frontend.vercel.app
PUBLIC_BASE_URL=https://your-backend.onrender.com
PLAYWRIGHT_BROWSERS_PATH=0
NODE_ENV=production
PORT=10000

# Optional local Redis fallback variables if you are not using REDIS_URL
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Currency conversion API used by the product detail drawer for live USD pricing.
# Example shape expected by the backend:
#   CURRENCY_API_URL=https://your-currency-provider.example/latest
#   CURRENCY_API_KEY=your-api-key
CURRENCY_API_URL=
CURRENCY_API_KEY=
CURRENCY_CACHE_TTL_MS=3600000
