{
  "name": "@amazon-intelligence/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "render:build": "node scripts/install-playwright-chromium.mjs && npx prisma generate && npx prisma db push && npm run build",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "seed": "tsx src/scripts/seed-categories.ts",
    "seed:history": "tsx src/scripts/seed-historical.ts",
    "test": "vitest run",
    "scrape:all": "tsx src/scripts/trigger-scrape.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^6.5.0",
    "axios": "^1.7.9",
    "bullmq": "^5.34.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^4.28.0",
    "ioredis": "^5.4.1",
    "playwright": "^1.49.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
